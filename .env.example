# .env
# Environment variables for the Learning Accelerator.
# Copy this file: cp .env.example .env
# Then fill in your values.

# ── Model configuration ───────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── Storage ───────────────────────────────────────────────────────────────────
CHECKPOINT_DB=data/checkpoints.db
NOTES_PATH=study_materials/sample_notes

# ── Langfuse observability ────────────────────────────────────────────────────
# Get keys from http://localhost:3000 after running: docker compose up -d
# Leave empty to run without observability (the system still works).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ── A2A service URLs ──────────────────────────────────────────────────────────
QUIZ_SERVICE_URL=http://localhost:9001
STUDY_BUDDY_URL=http://localhost:9002

# ── A2A feature toggles ───────────────────────────────────────────────────────
# Set to "false" to use local quiz generation instead of the A2A service.
# Useful when running main.py without starting the A2A services first.
USE_A2A_QUIZ=true

# Set to "false" to skip CrewAI Study Buddy calls when scores are low.
USE_STUDY_BUDDY=true
